local Cerrar = Instance.new("TextButton")
Cerrar.Parent = Content
Cerrar.BackgroundColor3 = Color3.fromRGB(70, 20, 20)
Cerrar.BorderSizePixel = 0
Cerrar.Text = "❌ CERRAR LIN"
