Cerrar.TextSize = 10
Cerrar.Font = Enum.Font.SourceSansBold
Cerrar.MouseButton1Click:Connect(function() SG:Destroy() end)
table.insert(Secciones["S7"], Cerrar)

ActualizarMenu()
