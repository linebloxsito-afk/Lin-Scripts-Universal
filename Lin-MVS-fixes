print("🔥 Lin Scripts MVS - GUI Ultra Pequeña cargada")

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")

local Antiban = true
local KillAura = false
local AutoShoot = true
local SilentAim = true
local WalkSpeed = 24

-- GUI ULTRA PEQUEÑA
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "LinTinyGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 220, 0, 380)   -- Muy pequeña
Frame.Position = UDim2.new(0.5, -110, 0.5, -190)
Frame.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
Frame.BorderSizePixel = 0
Frame.Parent = ScreenGui

-- Movible
local dragging = false
local dragInput
local dragStart
local startPos

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)

Frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        local delta = dragInput.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Título compacto
local Title = Instance.new("TextLabel")
Title.Text = "Lin MVS"
Title.Size = UDim2.new(1, 0, 0, 35)
Title.BackgroundColor3 = Color3.fromRGB(180, 0, 70)
Title.TextColor3 = Color3.new(1,1,1)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 16
Title.Parent = Frame

-- Cerrar
local CloseBtn = Instance.new("TextButton")
CloseBtn.Text = "✕"
CloseBtn.Size = UDim2.new(0, 25, 0, 25)
CloseBtn.Position = UDim2.new(1, -30, 0, 5)
CloseBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
CloseBtn.TextColor3 = Color3.new(1,1,1)
CloseBtn.TextSize = 18
CloseBtn.Parent = Frame
CloseBtn.MouseButton1Click:Connect(function() Frame.Visible = false end)

-- Reabrir
LocalPlayer.Chatted:Connect(function(msg)
    if msg:lower() == "lin" then Frame.Visible = true end
end)

-- Tabs Container (pequeño)
local TabContainer = Instance.new("Frame")
TabContainer.Size = UDim2.new(1, 0, 1, -35)
TabContainer.Position = UDim2.new(0, 0, 0, 35)
TabContainer.BackgroundTransparency = 1
TabContainer.Parent = Frame

local tabs = {}
for i = 1, 7 do
    local tab = Instance.new("ScrollingFrame")
    tab.Size = UDim2.new(1, 0, 1, 0)
    tab.BackgroundTransparency = 1
    tab.ScrollBarThickness = 4
    tab.Visible = (i == 1)
    tab.Parent = TabContainer
    tabs[i] = tab
end

-- Navegación compacta
local navNames = {"Combat","Unlock","Move","Vis","Farm","Troll","Extra"}
for i, name in ipairs(navNames) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.142, 0, 0, 28)
    btn.Position = UDim2.new((i-1)*0.142, 0, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    btn.Text = name
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextSize = 12
    btn.Parent = Frame
    btn.MouseButton1Click:Connect(function()
        for k, t in pairs(tabs) do t.Visible = (k == i) end
    end)
end

-- Función botones compactos
local function addBtn(tab, text, color, callback)
    local count = #tab:GetChildren()
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.92, 0, 0, 32)
    btn.Position = UDim2.new(0.04, 0, 0, 8 + count * 38)
    btn.BackgroundColor3 = color or Color3.fromRGB(35, 35, 45)
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextSize = 13
    btn.Parent = tab
    btn.MouseButton1Click:Connect(callback)
end

-- Tab 1: Combat
addBtn(tabs[1], "Kill Aura", Color3.fromRGB(200,0,0), function() KillAura = not KillAura end)
addBtn(tabs[1], "Loop Kill", Color3.fromRGB(180,0,0), function() LoopKill = not LoopKill end)
addBtn(tabs[1], "Auto Shoot", Color3.fromRGB(0,200,0), function() AutoShoot = not AutoShoot end)
addBtn(tabs[1], "Silent Aim", Color3.fromRGB(0,200,0), function() SilentAim = not SilentAim end)

-- Tab 2: Unlock
addBtn(tabs[2], "🔓 UNLOCK ALL", Color3.fromRGB(0,170,255), function()
    spawn(function()
        local data = LocalPlayer:FindFirstChild("PlayerData") or LocalPlayer:WaitForChild("PlayerData", 3)
        if data then
            for _, v in pairs(data:GetDescendants()) do
                if v:IsA("BoolValue") then v.Value = true end
                if v:IsA("IntValue") then v.Value = 999999 end
            end
        end
    end)
end)

-- Tab 3: Movement
addBtn(tabs[3], "Speed +", nil, function()
    WalkSpeed = WalkSpeed + 8
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = WalkSpeed end
end)
addBtn(tabs[3], "Speed -", nil, function()
    WalkSpeed = math.max(16, WalkSpeed - 8)
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
    if hum then hum.WalkSpeed = WalkSpeed end
end)

